# Local compose settings. Copy to .env or run ./scripts/bootstrap.sh.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_COLLECTION_NAME=memories
APP_DB_NAME=mem0_app

JWT_SECRET=
AUTH_DISABLED=false
MEM0_TELEMETRY=false

API_PORT=8888
DASHBOARD_PORT=3000
POSTGRES_PORT=8432

ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=

# Low-footprint local embedding model served by Ollama.
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
MEM0_DEFAULT_EMBEDDER_DIMS=768

# Chat LLM comes from ~/.openapi:
# - raw token in ~/.openapi is accepted as OPENAI_API_KEY
# - env-file style ~/.openapi can also set OPENAI_API_KEY/OPENAI_BASE_URL/MEM0_DEFAULT_LLM_MODEL
OPENAI_BASE_URL=
MEM0_DEFAULT_LLM_MODEL=
