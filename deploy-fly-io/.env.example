# OpenMemory Environment Variables
# Run: ./deploy-fly-io/scripts/generate-secrets.sh

# Required
OPENAI_API_KEY=sk-...

# Neon PostgreSQL (get from neon.tech dashboard, quotes required)
NEON_CONNECTION_STRING="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# OAuth (for Claude Desktop / MCP)
OAUTH_CLIENT_ID=openmemory
OAUTH_CLIENT_SECRET=

# UI Dashboard
UI_USERNAME=admin
UI_PASSWORD=
SESSION_SECRET=
