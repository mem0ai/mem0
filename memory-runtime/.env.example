MEMORY_RUNTIME_APP_NAME=Agent Memory Runtime
MEMORY_RUNTIME_ENV=development
MEMORY_RUNTIME_DEBUG=false
MEMORY_RUNTIME_API_PREFIX=/v1
MEMORY_RUNTIME_API_PORT=8080
MEMORY_RUNTIME_AUTO_CREATE_TABLES=true
