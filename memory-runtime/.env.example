MEMORY_RUNTIME_APP_NAME=Agent Memory Runtime
MEMORY_RUNTIME_ENV=development
MEMORY_RUNTIME_DEBUG=false
MEMORY_RUNTIME_API_PREFIX=/v1
MEMORY_RUNTIME_API_PORT=8080
MEMORY_RUNTIME_WORKER_POLL_SECONDS=2.0
MEMORY_RUNTIME_WORKER_STALE_AFTER_SECONDS=30.0
MEMORY_RUNTIME_STALLED_JOB_AFTER_SECONDS=60.0
MEMORY_RUNTIME_AUTO_CREATE_TABLES=true
MEMORY_RUNTIME_POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5433/memory_runtime
MEMORY_RUNTIME_REDIS_URL=redis://localhost:6379/0
MEMORY_RUNTIME_MEM0_BRIDGE_ENABLED=false
MEMORY_RUNTIME_MEM0_BASE_URL=http://localhost:8000
MEMORY_RUNTIME_MEM0_API_KEY=
MEMORY_RUNTIME_MEM0_TIMEOUT_SECONDS=5.0
