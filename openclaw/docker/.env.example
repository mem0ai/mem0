# OpenClaw + Mem0 Docker Setup
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required (one of these depending on mode) ───────────────────────────────

# Platform mode: Mem0 Cloud API key from https://app.mem0.ai
MEM0_API_KEY=

# OSS mode: OpenAI key for embeddings, LLM, and the OpenClaw agent
# Platform mode: only needed if you want a specific LLM for the agent itself
OPENAI_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# User ID for memory scoping (defaults to your OS username)
MEM0_USER_ID=

# Web UI port (default: 18789)
OPENCLAW_PORT=18789

# Config directory on host (default: ~/.openclaw)
# OPENCLAW_CONFIG_DIR=~/.openclaw

# Timezone (default: UTC)
TZ=UTC
