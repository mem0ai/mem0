OPENAI_API_KEY=sk-xxx
USER=user

# LLM Configuration (optional - defaults to openai/gpt-4o-mini)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:latest
# LLM_API_KEY=
# LLM_BASE_URL=
# OLLAMA_BASE_URL=http://localhost:11434

# Embedder Configuration (optional - defaults to openai/text-embedding-3-small)
# EMBEDDER_PROVIDER=ollama
# EMBEDDER_MODEL=nomic-embed-text
# EMBEDDER_API_KEY=
# EMBEDDER_BASE_URL=
# Set when your embedder produces vectors of a non-default size (vector stores
# default to 1536). e.g. nomic-embed-text outputs 768-dim vectors.
# EMBEDDER_EMBEDDING_DIMS=768
