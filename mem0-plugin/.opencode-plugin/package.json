{
  "name": "@mem0ai/opencode-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Mem0 persistent memory plugin for OpenCode — add, search, and manage memories across sessions",
  "main": "opencode-mem0.ts",
  "bin": {
    "mem0-opencode": "./cli.ts"
  },
  "license": "Apache-2.0",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mem0",
    "memory",
    "mcp",
    "ai-memory",
    "persistent-memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mem0ai/mem0",
    "directory": "mem0-plugin/.opencode-plugin"
  },
  "files": [
    "opencode-mem0.ts",
    "cli.ts",
    "opencode.json",
    "tsconfig.json",
    "LICENSE",
    "skills/**"
  ],
  "scripts": {
    "prepack": "rm -f skills && cp -r ../skills ./skills",
    "postpack": "rm -rf skills && ln -s ../skills skills"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.11",
    "mem0ai": "^3.0.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
